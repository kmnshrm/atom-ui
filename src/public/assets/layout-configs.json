{
  "copilot": {
    "name": "GitHub Copilot Layout",
    "description": "2-region layout with editor and copilot assistant",
    "direction": "horizontal",
    "clearExisting": true,
    "saveState": false,
    "regions": [
      {
        "id": "editor-region",
        "title": "Editor",
        "position": "start",
        "size": 70,
        "minSize": 30,
        "panels": [
          {
            "title": "Welcome.js",
            "icon": "fas fa-code",
            "closable": true,
            "content": {
              "type": "html",
              "html": "<div style=\"padding:16px;font-family:monospace;background:#0d1117;color:#c9d1d9;height:100%;overflow:auto;\"><div style=\"color:#ff7b72;margin-bottom:8px;\">// Welcome to GitHub Copilot Layout Demo</div><div style=\"color:#8b949e;margin-bottom:16px;\">// This is a 2-region layout (70:30)</div><pre style=\"color:#79c0ff;\">function <span style=\"color:#d2a8ff;\">welcome</span>() {\n  console.<span style=\"color:#d2a8ff;\">log</span>(<span style=\"color:#a5d6ff;\">'🚀 Ready to code with Copilot!'</span>);\n}</pre><div style=\"margin-top:16px;color:#8b949e;\">// Editor Region (70%)</div></div>"
            }
          }
        ]
      },
      {
        "id": "copilot-region",
        "title": "Copilot",
        "position": "end",
        "size": 30,
        "minSize": 20,
        "panels": [
          {
            "title": "GitHub Copilot",
            "icon": "fas fa-robot",
            "closable": false,
            "content": {
              "type": "html",
              "html": "<div style=\"padding:16px;background:#1e1e1e;color:#e5e7eb;height:100%;overflow:auto;\"><div style=\"display:flex;align-items:center;gap:8px;margin-bottom:16px;\"><i class=\"fas fa-robot\" style=\"color:#7c3aed;font-size:24px;\"></i><h3 style=\"margin:0;color:#7c3aed;\">GitHub Copilot</h3></div><div style=\"background:#2d2d2d;border-left:3px solid #3DCD58;padding:12px;border-radius:6px;margin-bottom:12px;\"><strong style=\"color:#3DCD58;display:block;margin-bottom:6px;\">👤 You</strong><p style=\"margin:0;\">Can you help me write a function to validate email addresses?</p></div><div style=\"background:#2d2d2d;border-left:3px solid #7c3aed;padding:12px;border-radius:6px;margin-bottom:12px;\"><strong style=\"color:#7c3aed;display:block;margin-bottom:6px;\">🤖 Copilot</strong><p style=\"margin:0 0 8px 0;\">Sure! Here's a function to validate email addresses:</p><pre style=\"background:#0d1117;padding:8px;border-radius:4px;overflow-x:auto;color:#c9d1d9;margin:0;\">function validateEmail(email) {\n  const regex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n  return regex.test(email);\n}</pre></div><div style=\"margin-top:16px;padding:10px;background:rgba(124,58,237,0.1);border-radius:6px;\"><div style=\"display:inline-flex;align-items:center;gap:6px;color:#a78bfa;font-size:12px;\"><i class=\"fas fa-circle\" style=\"font-size:8px;\"></i><span>Copilot Active (30%)</span></div></div></div>"
            }
          }
        ]
      }
    ]
  },
