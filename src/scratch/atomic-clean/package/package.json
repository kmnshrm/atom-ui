{
  "name": "atomicuilibrary",
  "version": "0.1.0",
  "description": "Stencil Component Starter",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/exploration-project-tailwind/exploration-project-tailwind.esm.js",
  "exports": {
    ".": {
      "import": "./dist/exploration-project-tailwind/exploration-project-tailwind.esm.js",
      "require": "./dist/exploration-project-tailwind/exploration-project-tailwind.cjs.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js",
      "require": "./loader/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stenciljs/component-starter.git"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "jest": {
    "setupFiles": [
      "<rootDir>/test-setup.js"
    ]
  },
  "scripts": {
    "build": "node --max-old-space-size=8192 ./node_modules/@stencil/core/bin/stencil build",
    "release": "npm version patch --no-git-tag-version && node --max-old-space-size=8192 ./node_modules/@stencil/core/bin/stencil build && npm pack",
    "test": " stencil test --spec --e2e",
    "test.watch": " stencil test --spec --e2e --watchAll",
    "generate": "stencil generate",
    "start": " stencil build --dev --watch --serve --no-open",
    "build:tailwind-dev": " postcss --postcss-config ./postcss.config.js src/global/app.scss -o src/styles/tailwind-optimized.css",
    "watch:tailwind-dev": " postcss --postcss-config ./postcss.config.js src/global/app.scss -o src/styles/tailwind-optimized.css --watch",
    "clean": "npx -y rimraf dist www loader",
    "build:css": "postcss src/app.scss -o dist/app.css",
    "version:minor": "npm version minor --no-git-tag-version",
    "predeploy": "npm run version:minor && npm run build",
    "deploy": "node scripts/deploy-gh-pages.cjs"
  },
  "devDependencies": {
    "@stencil/angular-output-target": "^1.1.1",
    "@stencil/sass": "^3.2.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "gh-pages": "^6.3.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "puppeteer": "^22.2.0",
    "sass": "^1.97.3"
  },
  "license": "MIT",
  "dependencies": {
    "@stencil/core": "^4.43.4",
    "@types/dompurify": "^3.0.5",
    "autoprefixer": "^10.4.22",
    "axe-core": "^4.11.0",
    "dompurify": "^3.3.3",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "rollup": "^4.35.0",
    "tailwindcss": "^3.4.18"
  },
  "overrides": {
    "npm": {
      "rollup": "npm:@rollup/wasm-node"
    }
  }
}
